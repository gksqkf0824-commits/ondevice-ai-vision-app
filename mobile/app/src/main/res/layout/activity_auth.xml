<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFD600"
    android:padding="28dp">

    <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="72dp">

        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_logo_icon"
            android:layout_marginBottom="16dp"
            android:layout_gravity="center">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_location_pin"
                android:contentDescription="@null"/>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="온길"
            android:textSize="42sp"
            android:textColor="#111111"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="안전한 이동을 위한\n스마트 교통 보조 서비스"
            android:textSize="13sp"
            android:textColor="#80000000"
            android:textAlignment="center"
            android:lineSpacingExtra="4dp"/>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLoginPersonal"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="개인 로그인"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="#111111"
        android:textColor="#FFD600"
        app:cornerRadius="12dp"
        android:layout_marginBottom="10dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLoginGuardian"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="보호자 로그인"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#111111"
        app:strokeColor="#33000000"
        app:strokeWidth="2dp"
        app:cornerRadius="12dp"
        android:layout_marginBottom="10dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLoginOrg"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="기관 로그인"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#111111"
        app:strokeColor="#33000000"
        app:strokeWidth="2dp"
        app:cornerRadius="12dp"
        android:layout_marginBottom="20dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"/>

    <TextView
        android:id="@+id/tvGoSignup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="회원가입"
        android:textSize="13sp"
        android:textColor="#66000000"
        android:layout_gravity="center"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clickable="true"
        android:focusable="true"/>

    <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="0.3"/>
</LinearLayout>
