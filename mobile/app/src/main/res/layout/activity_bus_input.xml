<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="28dp"
    android:background="#FFD600">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="버스 이용 예정이신가요?"
        android:textSize="22sp"
        android:textColor="#111111"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="이용하실 버스 번호를 입력해보세요"
        android:textSize="13sp"
        android:textColor="#66000000"
        android:textAlignment="center"
        android:layout_marginBottom="32dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_input_light"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="20dp">

        <EditText
            android:id="@+id/etBusNumber"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:background="@null"
            android:hint="버스 번호 입력"
            android:textColorHint="#40000000"
            android:textColor="#111111"
            android:textSize="18sp"
            android:textStyle="bold"
            android:inputType="number"/>

        <ImageView
            android:id="@+id/btnMic"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_mic_icon"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="음성으로 입력하기"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="52dp"
            android:layout_marginEnd="8dp"
            android:text="취소"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#66000000"
            app:backgroundTint="#14000000"
            app:cornerRadius="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirm"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:text="확인"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFD600"
            app:backgroundTint="#111111"
            app:cornerRadius="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSkip"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="건너뛰기"
        android:textSize="13sp"
        android:textColor="#66000000"
        android:layout_gravity="center"/>
</LinearLayout>
