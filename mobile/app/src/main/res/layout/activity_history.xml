<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFD600">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_back_btn_light"
            android:text="‹"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginEnd="12dp"
            android:contentDescription="뒤로 가기"/>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="이용자 기록 확인"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#111111"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="최근 기록"
            android:textSize="12sp"
            android:textColor="#66000000"/>

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="120dp"
            android:background="@drawable/bg_input_light"
            android:paddingHorizontal="12dp"
            android:hint="검색 🔍"
            android:textSize="13sp"
            android:textColor="#111111"
            android:textColorHint="#66000000"
            android:singleLine="true"/>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp"
            android:clipToPadding="false"/>

        <ScrollView
            android:id="@+id/layoutGraph"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/chartContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"/>
        </ScrollView>
    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnToggleGraph"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginVertical="12dp"
        android:text="위험 객체 위치 로그"
        android:textSize="14sp"
        android:textStyle="bold"
        app:backgroundTint="#111111"
        android:textColor="#FFD600"
        app:cornerRadius="12dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"/>
</LinearLayout>
