<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111111"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_tab_bar_dark"
        android:padding="3dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tabLoginPersonal"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="개인"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#4DFFFFFF"/>

        <TextView
            android:id="@+id/tabLoginOrg"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="기관"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#4DFFFFFF"/>

        <TextView
            android:id="@+id/tabLoginGuardian"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="보호자"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#4DFFFFFF"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvLoginTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="개인 로그인"
        android:textSize="24sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="아이디와 비밀번호를 입력하세요"
        android:textSize="12sp"
        android:textColor="#59FFFFFF"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="아이디"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#59FFFFFF"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etId"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_input_dark"
        android:paddingHorizontal="16dp"
        android:hint="아이디를 입력하세요"
        android:textColorHint="#33FFFFFF"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="비밀번호"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#59FFFFFF"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_input_dark"
        android:paddingHorizontal="16dp"
        android:hint="비밀번호를 입력하세요"
        android:inputType="textPassword"
        android:textColorHint="#33FFFFFF"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"/>

    <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="52dp"
            android:layout_marginEnd="8dp"
            android:text="취소"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#80FFFFFF"
            app:backgroundTint="#0FFFFFFF"
            app:cornerRadius="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLoginConfirm"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:text="확인"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#111111"
            app:backgroundTint="#FFD600"
            app:cornerRadius="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>
    </LinearLayout>
</LinearLayout>
