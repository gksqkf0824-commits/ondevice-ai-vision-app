<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="로고 미정"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="40dp"/>

    <LinearLayout
        android:id="@+id/btnGoCamera"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#E0E0E0"
        android:padding="20dp"
        android:layout_marginBottom="12dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="카메라 인식, 카메라를 사용하여 물체를 인식합니다">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="카메라 인식" android:textSize="22sp" android:textStyle="bold" android:textColor="#000000"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="카메라를 사용하여 물체를 인식합니다" android:textSize="14sp" android:textColor="#333333"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btnGoGallery"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#E0E0E0"
        android:padding="20dp"
        android:layout_marginBottom="12dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="이미지 첨부, 이미지를 첨부하여 인식을 진행합니다">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="이미지 첨부" android:textSize="22sp" android:textStyle="bold" android:textColor="#000000"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="이미지를 첨부하여 인식을 진행합니다" android:textSize="14sp" android:textColor="#333333"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btnGoHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#E0E0E0"
        android:padding="20dp"
        android:layout_marginBottom="12dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="인식 기록 확인, 과거 인식 기능을 사용했던 기록을 조회합니다">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="인식 기록 확인" android:textSize="22sp" android:textStyle="bold" android:textColor="#000000"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="과거 인식 기능을 사용했던 기록을 조회합니다" android:textSize="14sp" android:textColor="#333333"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btnGoSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#E0E0E0"
        android:padding="20dp"
        android:layout_marginBottom="12dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="설정, 설정을 변경합니다">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="설정" android:textSize="22sp" android:textStyle="bold" android:textColor="#000000"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="설정을 변경합니다" android:textSize="14sp" android:textColor="#333333"/>
    </LinearLayout>
</LinearLayout>