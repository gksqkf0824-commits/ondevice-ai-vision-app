<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111111">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="12dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_back_btn_dark"
            android:text="‹"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFD600"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginEnd="12dp"
            android:contentDescription="뒤로 가기"/>

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="설정"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="20dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="사용자 정보"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#40FFFFFF"
                android:textAllCaps="true"
                android:letterSpacing="0.15"
                android:layout_marginBottom="10dp"
                android:layout_marginTop="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_settings_card"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="기관명"
                        android:textSize="13sp"
                        android:textColor="#B3FFFFFF"/>
                    <TextView
                        android:id="@+id/tvOrgValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="미소속"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFD600"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#0AFFFFFF"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="사용자명"
                        android:textSize="13sp"
                        android:textColor="#B3FFFFFF"/>
                    <TextView
                        android:id="@+id/tvNameValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="사용자1"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFD600"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#0AFFFFFF"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="전화번호"
                        android:textSize="13sp"
                        android:textColor="#B3FFFFFF"/>
                    <TextView
                        android:id="@+id/tvPhoneValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFD600"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="보호자 정보"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#40FFFFFF"
                android:textAllCaps="true"
                android:letterSpacing="0.15"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:id="@+id/layoutUnlinkedGuardian"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_settings_card"
                android:padding="20dp"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="보호자 정보가 없습니다"
                    android:textSize="13sp"
                    android:textColor="#66FFFFFF"
                    android:layout_marginBottom="16dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLinkGuardian"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    app:backgroundTint="#FFD600"
                    android:textColor="#111111"
                    android:text="보호자 연동"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="10dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingHorizontal="24dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutLinkedGuardian"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_settings_card"
                android:layout_marginBottom="20dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="보호자명"
                        android:textSize="13sp"
                        android:textColor="#B3FFFFFF"/>
                    <TextView
                        android:id="@+id/tvGuardianNameValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFD600"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#0AFFFFFF"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="보호자 번호"
                        android:textSize="13sp"
                        android:textColor="#B3FFFFFF"/>
                    <TextView
                        android:id="@+id/tvGuardianPhoneValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFD600"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="앱 설정"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#40FFFFFF"
                android:textAllCaps="true"
                android:letterSpacing="0.15"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_settings_card"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="알림 설정"
                        android:textSize="13sp"
                        android:textColor="#B3FFFFFF"/>
                    <Switch
                        android:id="@+id/switchNotification"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:contentDescription="알림 설정 스위치"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            app:backgroundTint="#1AFF3B30"
            android:textColor="#FF3B30"
            android:text="로그 아웃"
            android:textSize="15sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:contentDescription="현재 계정 로그아웃 버튼"/>
    </LinearLayout>
</LinearLayout>
