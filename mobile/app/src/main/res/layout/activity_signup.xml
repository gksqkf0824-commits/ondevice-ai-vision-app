<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFD600"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_tab_bar_light"
        android:padding="3dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tabPersonal"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="개인"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:background="@drawable/bg_tab_active_dark"/>

        <TextView
            android:id="@+id/tabOrg"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="기관"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#59000000"/>

        <TextView
            android:id="@+id/tabGuardian"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="보호자"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#59000000"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="회원가입"
        android:textSize="24sp"
        android:textColor="#111111"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="이용자 정보를 입력하세요"
        android:textSize="12sp"
        android:textColor="#66000000"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etOrgName"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_input_light"
        android:paddingHorizontal="16dp"
        android:hint="기관명"
        android:textColorHint="#40000000"
        android:textColor="#111111"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"/>

    <EditText
        android:id="@+id/etName"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_input_light"
        android:paddingHorizontal="16dp"
        android:hint="사용자명"
        android:textColorHint="#40000000"
        android:textColor="#111111"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"/>

    <EditText
        android:id="@+id/etId"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_input_light"
        android:paddingHorizontal="16dp"
        android:hint="아이디"
        android:textColorHint="#40000000"
        android:textColor="#111111"
        android:textSize="15sp"
        android:textStyle="bold"/>

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_input_light"
        android:paddingHorizontal="16dp"
        android:hint="비밀번호"
        android:inputType="textPassword"
        android:textColorHint="#40000000"
        android:textColor="#111111"
        android:textSize="15sp"
        android:textStyle="bold"/>

    <EditText
        android:id="@+id/etPasswordConfirm"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_input_light"
        android:paddingHorizontal="16dp"
        android:hint="비밀번호 확인"
        android:inputType="textPassword"
        android:textColorHint="#40000000"
        android:textColor="#111111"
        android:textSize="15sp"
        android:textStyle="bold"/>

    <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="52dp"
            android:layout_marginEnd="8dp"
            android:text="취소"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#66000000"
            app:backgroundTint="#14000000"
            app:cornerRadius="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSignup"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:text="확인"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFD600"
            app:backgroundTint="#111111"
            app:cornerRadius="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>
    </LinearLayout>
</LinearLayout>
