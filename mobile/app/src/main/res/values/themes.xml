<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Ondevice" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/app_yellow</item>
        <item name="android:navigationBarColor">@color/app_yellow</item>
        <item name="colorPrimary">@color/app_yellow</item>
        <item name="colorOnPrimary">@color/app_black</item>
        <item name="colorSecondary">@color/app_black</item>
        <item name="android:colorAccent">@color/app_yellow</item>
    </style>

    <style name="Theme.Ondevice" parent="Base.Theme.Ondevice" />
</resources>
